{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "K-Clock",
  "version": "1.0.1",
  "identifier": "com.kris.clock",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "K-Clock",
        "width": 300,
        "height": 90,
        "minWidth": 200,
        "minHeight": 90,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "center": true,
        "shadow": false
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": ["icons/icon.ico"],
    "windows": {
      "nsis": {
        "languages": ["Korean"],
        "displayLanguageSelector": false
      }
    },
    "publisher": "KrisB",
    "copyright": "KrisB 2026"
  },
  "plugins": {}

}
